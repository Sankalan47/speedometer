# Local development — used when running the backend outside Docker
NODE_ENV=development
PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_USER=speeduser
DB_PASSWORD=speedpass
DB_NAME=speedometer
HISTORY_ON_CONNECT=10
HEARTBEAT_INTERVAL_MS=30000
SENSOR_INTERVAL_MS=1000
PRUNE_KEEP_ROWS=10000
CORS_ORIGIN=http://localhost:5173
SENSOR_ID=sensor-1
