# PostgreSQL credentials (used by postgres + backend + simulator services)
POSTGRES_USER=speeduser
POSTGRES_PASSWORD=speedpass
POSTGRES_DB=speedometer

# Backend
NODE_ENV=production
PORT=3001
DB_HOST=postgres
DB_PORT=5432
DB_USER=speeduser
DB_PASSWORD=speedpass
DB_NAME=speedometer
HISTORY_ON_CONNECT=10
HEARTBEAT_INTERVAL_MS=30000
SENSOR_INTERVAL_MS=1000
PRUNE_KEEP_ROWS=10000

# CORS — set to your Netlify URL in production (e.g. https://my-app.netlify.app)
# Use * for local development only
CORS_ORIGIN=*

# Simulator
SENSOR_ID=sensor-1

# Caddy reverse proxy — set to your domain (e.g. yourname.duckdns.org)
# Caddy obtains a Let's Encrypt cert automatically.
# Ports 80 and 443 must be open and the domain must point to this server's IP.
DOMAIN=yourname.duckdns.org
